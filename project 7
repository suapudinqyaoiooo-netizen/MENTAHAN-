local library = loadstring(game:HttpGet("https://raw.githubusercontent.com/liebertsx/Tora-Library/main/src/librarynew"))()

local window = library:CreateWindow("Chase A Lucky blocks")

local autoBrainrotEnabled = false
local sessionId = 0
local activeThread = nil

local player = game.Players.LocalPlayer
local rs = game:GetService("ReplicatedStorage")

local remoteStart = rs:WaitForChild("Remotes"):WaitForChild("ClientToServer"):WaitForChild("StartLineCrossed")
local remoteUnbox = rs:WaitForChild("Remotes"):WaitForChild("ClientToServer"):WaitForChild("UnboxAnimationDone")
local remoteHome = rs:WaitForChild("Remotes"):WaitForChild("ClientToServer"):WaitForChild("HomeTeleport")

local startPos = Vector3.new(-26.3287, 30.7480, -2136.2717)
local endPos = Vector3.new(-228.90187, 4.16676, 575.27209)

local function isActive(sid)
    return autoBrainrotEnabled and sessionId == sid
end

local function detectUnbox(timeout, sid)
    local gui = player:WaitForChild("PlayerGui")
    local before = {}
    for _,v in pairs(gui:GetDescendants()) do
        before[v] = true
    end
    local t0 = tick()
    while tick() - t0 < timeout do
        if not isActive(sid) then return false end
        task.wait(0.005)
        for _,v in pairs(gui:GetDescendants()) do
            if not before[v] then
                return true
            end
        end
    end
    return false
end

local function runCycle(sid)
    if not isActive(sid) then return end

    local char = player.Character or player.CharacterAdded:Wait()
    if not isActive(sid) then return end

    remoteStart:FireServer()
    task.wait(0.01)
    if not isActive(sid) then return end
    remoteStart:FireServer()
    task.wait(0.01)
    if not isActive(sid) then return end
    remoteStart:FireServer()
    task.wait(0.01)
    if not isActive(sid) then return end

    local detected = false
    local t0 = tick()

    while tick() - t0 < 3 do
        if not isActive(sid) then return end
        char = player.Character
        if char then
            char:PivotTo(CFrame.new(startPos))
        end
        if detectUnbox(0.01, sid) then
            detected = true
            break
        end
        task.wait(0.005)
    end

    if not isActive(sid) then return end

    if detected then
        remoteUnbox:FireServer()
        task.wait(0.05)
        if not isActive(sid) then return end
        char = player.Character or player.CharacterAdded:Wait()
        if not isActive(sid) then return end
        task.wait(0.05)
        if not isActive(sid) then return end
        local t1 = tick()
        while tick() - t1 < 1 do
            if not isActive(sid) then return end
            char = player.Character
            if char then
                char:PivotTo(CFrame.new(endPos))
            end
            task.wait(0.005)
        end
    end
end

local function forceReset()
    pcall(function() player:LoadCharacter() end)
    pcall(function()
        local char = player.Character
        if char then
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then hum.Health = 0 end
        end
    end)
end

local function fixCamera()
    -- loop paksa kamera custom selama 3 detik
    task.spawn(function()
        local t = tick()
        while tick() - t < 3 do
            pcall(function()
                local cam = workspace.CurrentCamera
                local char = player.Character
                if cam and char then
                    cam.CameraType = Enum.CameraType.Custom
                    cam.CameraSubject = char:FindFirstChildOfClass("Humanoid")
                end
            end)
            task.wait(0.1)
        end
    end)
end

local function doHome()
    pcall(function() remoteHome:FireServer() end)
    task.wait(0.5)
    fixCamera()
end

local function stopAll()
    autoBrainrotEnabled = false
    sessionId = sessionId + 1
    if activeThread then
        pcall(task.cancel, activeThread)
        activeThread = nil
    end

    task.spawn(function()
        local respawned = false
        local conn = player.CharacterAdded:Connect(function()
            respawned = true
        end)

        local t0 = tick()
        while tick() - t0 < 3 do
            forceReset()
            task.wait(0.2)
            if respawned then break end
        end

        conn:Disconnect()

        if respawned then
            task.wait(0.5)
            doHome()
        else
            local respawned2 = false
            local conn2 = player.CharacterAdded:Connect(function()
                respawned2 = true
            end)

            local t1 = tick()
            while tick() - t1 < 3 do
                forceReset()
                task.wait(0.2)
                if respawned2 then break end
            end

            conn2:Disconnect()
            task.wait(0.5)

            for i = 1, 5 do
                pcall(function() remoteHome:FireServer() end)
                task.wait(0.1)
            end
            fixCamera()
        end
    end)
end

window:AddToggle({
    text = "Auto Brainrot",
    state = false,
    callback = function(state)
        if state then
            stopAll()
            autoBrainrotEnabled = true
            sessionId = sessionId + 1
            local sid = sessionId
            activeThread = task.spawn(function()
                while isActive(sid) do
                    runCycle(sid)
                    task.wait()
                end
            end)
        else
            stopAll()
        end
    end
})

window:AddLabel({text = "Credit : Rilzzhub"})

library:Init()