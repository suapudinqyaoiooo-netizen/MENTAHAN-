
-- ═══════════════════════════════════════
--             SERVICES
-- ═══════════════════════════════════════

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer
local rs = ReplicatedStorage

-- ═══════════════════════════════════════
--             REMOTES
-- ═══════════════════════════════════════

local Remotes = rs:WaitForChild("Remotes"):WaitForChild("ClientToServer")
local PickupRemote = Remotes:WaitForChild("Prompt"):WaitForChild("PickupRemote")
local remoteStart = Remotes:WaitForChild("StartLineCrossed")
local remoteUnbox = Remotes:WaitForChild("UnboxAnimationDone")
local remoteHome = Remotes:WaitForChild("HomeTeleport")
local UpdateTriggered = Remotes:WaitForChild("UpdateTriggered")

-- ═══════════════════════════════════════
--             STATE
-- ═══════════════════════════════════════

local autoBrainrotEnabled = false
local sessionId = 0
local activeThread = nil
local startPos = Vector3.new(-26.3287, 30.7480, -2136.2717)
local endPos = Vector3.new(-228.90187, 4.16676, 575.27209)

local selectedUpgradeSlot = 1
local isUpgradeRunning = false
local isCollectRunning = false

-- ═══════════════════════════════════════
--        AUTO BRAINROT HELPERS
-- ═══════════════════════════════════════

local function isActive(sid)
    return autoBrainrotEnabled and sessionId == sid
end

local function detectUnbox(timeout, sid)
    local gui = player:WaitForChild("PlayerGui")
    local before = {}
    for _, v in pairs(gui:GetDescendants()) do
        before[v] = true
    end
    local t0 = tick()
    while tick() - t0 < timeout do
        if not isActive(sid) then return false end
        task.wait(0.005)
        for _, v in pairs(gui:GetDescendants()) do
            if not before[v] then return true end
        end
    end
    return false
end

local function runCycle(sid)
    if not isActive(sid) then return end
    local char = player.Character or player.CharacterAdded:Wait()
    if not isActive(sid) then return end

    remoteStart:FireServer() task.wait(0.01)
    if not isActive(sid) then return end
    remoteStart:FireServer() task.wait(0.01)
    if not isActive(sid) then return end
    remoteStart:FireServer() task.wait(0.01)
    if not isActive(sid) then return end

    local detected = false
    local t0 = tick()
    while tick() - t0 < 3 do
        if not isActive(sid) then return end
        char = player.Character
        if char then char:PivotTo(CFrame.new(startPos)) end
        if detectUnbox(0.01, sid) then detected = true break end
        task.wait(0.005)
    end

    if not isActive(sid) then return end

    if detected then
        remoteUnbox:FireServer()
        task.wait(0.05)
        if not isActive(sid) then return end
        char = player.Character or player.CharacterAdded:Wait()
        if not isActive(sid) then return end
        task.wait(0.05)
        if not isActive(sid) then return end
        local t1 = tick()
        while tick() - t1 < 1 do
            if not isActive(sid) then return end
            char = player.Character
            if char then char:PivotTo(CFrame.new(endPos)) end
            task.wait(0.005)
        end
    end
end

local function fixCamera()
    task.spawn(function()
        local t = tick()
        while tick() - t < 3 do
            pcall(function()
                local cam = workspace.CurrentCamera
                local char = player.Character
                if cam and char then
                    cam.CameraType = Enum.CameraType.Custom
                    cam.CameraSubject = char:FindFirstChildOfClass("Humanoid")
                end
            end)
            task.wait(0.1)
        end
    end)
end

local function forceReset()
    pcall(function() player:LoadCharacter() end)
    pcall(function()
        local char = player.Character
        if char then
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then hum.Health = 0 end
        end
    end)
end

local function doHome()
    pcall(function() remoteHome:FireServer() end)
    task.wait(0.5)
    fixCamera()
end

local function stopAll()
    autoBrainrotEnabled = false
    sessionId = sessionId + 1
    if activeThread then
        pcall(task.cancel, activeThread)
        activeThread = nil
    end
    task.spawn(function()
        local respawned = false
        local conn = player.CharacterAdded:Connect(function() respawned = true end)
        local t0 = tick()
        while tick() - t0 < 3 do
            forceReset() task.wait(0.2)
            if respawned then break end
        end
        conn:Disconnect()
        if respawned then
            task.wait(0.5)
            doHome()
        else
            local respawned2 = false
            local conn2 = player.CharacterAdded:Connect(function() respawned2 = true end)
            local t1 = tick()
            while tick() - t1 < 3 do
                forceReset() task.wait(0.2)
                if respawned2 then break end
            end
            conn2:Disconnect()
            task.wait(0.5)
            for i = 1, 5 do
                pcall(function() remoteHome:FireServer() end)
                task.wait(0.1)
            end
            fixCamera()
        end
    end)
end

-- ═══════════════════════════════════════
--        AUTO UPGRADE
-- ═══════════════════════════════════════

local function runUpgradeLoop()
    isUpgradeRunning = true
    while isUpgradeRunning do
        pcall(function()
            UpdateTriggered:FireServer(selectedUpgradeSlot)
        end)
        task.wait(0.1)
    end
end

-- ═══════════════════════════════════════
--        AUTO COLLECT
-- ═══════════════════════════════════════

local collectKeywords = {"pad"}

local function isCollectTarget(part)
    if not part:IsA("BasePart") then return false end
    local name = part.Name:lower()
    for _, k in ipairs(collectKeywords) do
        if name:find(k) then return true end
    end
    return false
end

local function doCollect()
    local char = player.Character or player.CharacterAdded:Wait()
    local hrp = char:WaitForChild("HumanoidRootPart")
    for _, obj in ipairs(workspace:GetDescendants()) do
        if isCollectTarget(obj) then
            pcall(function()
                firetouchinterest(hrp, obj, 0)
                firetouchinterest(hrp, obj, 1)
            end)
        end
    end
end

local function runCollectLoop()
    isCollectRunning = true
    while isCollectRunning do
        pcall(doCollect)
        task.wait(2)
    end
end

-- ═══════════════════════════════════════
--          GUI - TORA LIBRARY
-- ═══════════════════════════════════════

local lib = loadstring(game:HttpGet("https://raw.githubusercontent.com/liebertsx/Tora-Library/main/src/librarynew"))()
local win = lib:CreateWindow("Chase A Lucky Blocks")

-- 1. Upgrade Slot (selector 1–40)
local upgradeSlotValues = {}
for i = 1, 40 do table.insert(upgradeSlotValues, tostring(i)) end

win:AddList({
    text = "Upgrade Slot",
    flag = "upgradeSlot",
    value = "1",
    values = upgradeSlotValues,
    callback = function(value)
        selectedUpgradeSlot = tonumber(value) or 1
    end
})

-- 2. Pickup All
win:AddButton({
    text = "Pickup All",
    callback = function()
        task.spawn(function()
            for i = 1, 40 do
                PickupRemote:FireServer(i)
                task.wait(0.05)
            end
        end)
    end
})

-- 3. Auto Brainrot
win:AddToggle({
    text = "Auto Brainrot",
    state = autoBrainrotEnabled,
    callback = function(state)
        if state then
            stopAll()
            autoBrainrotEnabled = true
            sessionId = sessionId + 1
            local sid = sessionId
            activeThread = task.spawn(function()
                while isActive(sid) do
                    runCycle(sid)
                    task.wait()
                end
            end)
        else
            stopAll()
        end
    end
})

-- 4. Auto Collect
win:AddToggle({
    text = "Auto Collect",
    state = false,
    callback = function(state)
        if state then
            task.spawn(runCollectLoop)
        else
            isCollectRunning = false
        end
    end
})

-- 5. Auto Upgrade
win:AddToggle({
    text = "Auto Upgrade",
    state = false,
    callback = function(state)
        if state then
            task.spawn(runUpgradeLoop)
        else
            isUpgradeRunning = false
        end
    end
})

win:AddLabel({text = "Credit : Rilzzhub"})

