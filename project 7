local library = loadstring(game:HttpGet("https://raw.githubusercontent.com/liebertsx/Tora-Library/main/src/librarynew"))()

local window = library:CreateWindow("Chase A Lucky blocks")

local autoBrainrotEnabled = false
local loopThread = nil

local toggle = window:AddToggle({
    text = "Auto Brainrot",
    state = false,
    callback = function(state)
        autoBrainrotEnabled = state

        if not state and loopThread then
            task.cancel(loopThread)
            loopThread = nil
        end

        if state then
            loopThread = task.spawn(function()
                while autoBrainrotEnabled do
                    runCycle()
                    task.wait(0.1)
                end
            end)
        end
    end
})

window:AddLabel({text = "Credit : Rilzzhub"})

library:Init()

local player = game.Players.LocalPlayer
local rs = game:GetService("ReplicatedStorage")

local remoteStart = rs:WaitForChild("Remotes"):WaitForChild("ClientToServer"):WaitForChild("StartLineCrossed")
local remoteUnbox = rs:WaitForChild("Remotes"):WaitForChild("ClientToServer"):WaitForChild("UnboxAnimationDone")

local startPos = Vector3.new(-26.3287, 30.7480, -2136.2717)
local endPos = Vector3.new(-228.90187, 4.16676, 575.27209)

local function detectUnbox(timeout)
    local gui = player:WaitForChild("PlayerGui")
    local before = {}
    for _,v in pairs(gui:GetDescendants()) do
        before[v] = true
    end
    local t0 = tick()
    while tick() - t0 < timeout do
        task.wait(0.005)
        for _,v in pairs(gui:GetDescendants()) do
            if not before[v] then
                return true
            end
        end
    end
    return false
end

function runCycle()
    local char = player.Character or player.CharacterAdded:Wait()

    for i = 1,3 do
        remoteStart:FireServer()
        task.wait(0.01)
    end

    local detected = false
    local t0 = tick()

    while autoBrainrotEnabled and tick() - t0 < 3 do
        task.wait(0.005)
        if char then
            char:PivotTo(CFrame.new(startPos))
        end
        if detectUnbox(0.01) then
            detected = true
            break
        end
    end

    if detected and autoBrainrotEnabled then
        remoteUnbox:FireServer()
        char = player.Character or player.CharacterAdded:Wait()
        task.wait(0.1)
        local t1 = tick()
        while autoBrainrotEnabled and tick() - t1 < 1 do
            if char then
                char:PivotTo(CFrame.new(endPos))
            end
            task.wait(0.005)
        end
    end
end