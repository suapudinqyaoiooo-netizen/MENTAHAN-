-- ==================== EARNINGS FARM FUNCTIONS ====================
local function parseEarnings(text)
    if not text or text == "" then return 0 end
    local numberStr, suffix = text:match("([%d%.]+)([kKmM]?)")
    if not numberStr then return 0 end
    local number = tonumber(numberStr) or 0
    if suffix == "k" or suffix == "K" then number *= 1000
    elseif suffix == "m" or suffix == "M" then number *= 1000000 end
    return number
end

local function getEarningsAndPrompt(item)
    local target = item:FindFirstChild("SpawnedItem") or item
    local infoGUI = target:FindFirstChild("InfoGUI")
    if not infoGUI then return 0, nil end
    local textLabels = infoGUI:FindFirstChild("TextLabels")
    if not textLabels then return 0, nil end
    local earningsLabel = textLabels:FindFirstChild("Earnings")
    if not earningsLabel then return 0, nil end
    
    local earnings = parseEarnings(earningsLabel.Text)
    local prompt = target:FindFirstChild("B18") or target:FindFirstChildWhichIsA("ProximityPrompt", true)
    return earnings, prompt
end

local function goToSafeZone()
    root.CFrame = SAFE_ZONE
    task.wait(0.6)
end

local function collectHighest()
    while autoFarm do
        local bestItem = nil
        local bestEarnings = -1
        local bestPrompt = nil
        
        for _, folder in ipairs(spawnFolders) do
            for _, child in ipairs(folder:GetChildren()) do
                local earnings, prompt = getEarningsAndPrompt(child)
                if earnings > bestEarnings and prompt and earnings > 0 then
                    bestEarnings = earnings
                    bestItem = child
                    bestPrompt = prompt
                end
            end
        end
        
        if bestItem and bestEarnings > 0 then
            print("ðŸŽ¯ Targeting: " .. bestItem.Name .. " | $" .. bestEarnings)
            
            local targetPart = bestItem:FindFirstChildWhichIsA("BasePart") or bestItem.PrimaryPart or bestItem:FindFirstChild("SpawnedItem")
            if targetPart then
                root.CFrame = targetPart.CFrame * CFrame.new(0, 6, 0)
                task.wait(0.5)
            end
            
            if bestPrompt then
                bestPrompt:InputHoldBegin()
                task.wait(0.25)
                bestPrompt:InputHoldEnd()
                task.wait(1.2)
            end
            
            goToSafeZone()
            task.wait(1)
        else
            goToSafeZone()
            task.wait(4)
        end
    end
end

