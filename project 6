local function AddDropdown(page, label, options, default, callback)
    local frame = Instance.new("Frame", page)
    frame.Size = UDim2.new(0, 240, 0, 35)
    frame.BackgroundColor3 = Theme.SurfaceLight
    frame.ClipsDescendants = true 
    frame.ZIndex = 12
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 6)

    local btn = Instance.new("TextButton", frame)
    btn.Size = UDim2.new(1, 0, 0, 35)
    btn.BackgroundTransparency = 1
    btn.Text = "  " .. label .. ": " .. tostring(default)
    btn.TextColor3 = Theme.Text
    btn.TextSize = 12
    btn.Font = Enum.Font.GothamBold
    btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.ZIndex = 13

    local arrow = Instance.new("TextLabel", frame)
    arrow.Size = UDim2.new(0, 20, 0, 35)
    arrow.Position = UDim2.new(1, -25, 0, 0)
    arrow.BackgroundTransparency = 1
    arrow.Text = "▼"
    arrow.TextColor3 = Theme.Accent
    arrow.TextSize = 10
    arrow.ZIndex = 13

    local scroll = Instance.new("ScrollingFrame", frame)
    scroll.Size = UDim2.new(1, 0, 1, -35)
    scroll.Position = UDim2.new(0, 0, 0, 35)
    scroll.BackgroundColor3 = Theme.SurfaceLight
    scroll.ScrollBarThickness = 2
    scroll.BorderSizePixel = 0
    scroll.BackgroundTransparency = 1
    scroll.ZIndex = 13
    local layout = Instance.new("UIListLayout", scroll)

    local isOpen = false
    btn.MouseButton1Click:Connect(function()
        isOpen = not isOpen
        if isOpen then
            arrow.Text = "▲"
            TweenService:Create(frame, TweenInfo.new(0.2), {Size = UDim2.new(0, 240, 0, 175)}):Play()
        else
            arrow.Text = "▼"
            TweenService:Create(frame, TweenInfo.new(0.2), {Size = UDim2.new(0, 240, 0, 35)}):Play()
        end
    end)

    local obj = {}
    function obj.UpdateOptions(newOptions)
        for _, child in pairs(scroll:GetChildren()) do
            if child:IsA("TextButton") then child:Destroy() end
        end
        
        for _, opt in ipairs(newOptions) do
            local optBtn = Instance.new("TextButton", scroll)
            optBtn.Size = UDim2.new(1, 0, 0, 28)
            optBtn.BackgroundColor3 = Theme.SurfaceLight
            optBtn.Text = tostring(opt)
            optBtn.TextColor3 = Theme.TextDim
            optBtn.TextSize = 11
            optBtn.Font = Enum.Font.GothamBold
            optBtn.BorderSizePixel = 0
            optBtn.BackgroundTransparency = 1
            optBtn.ZIndex = 14

            optBtn.MouseButton1Click:Connect(function()
                btn.Text = "  " .. label .. ": " .. tostring(opt)
                isOpen = false
                arrow.Text = "▼"
                TweenService:Create(frame, TweenInfo.new(0.2), {Size = UDim2.new(0, 240, 0, 35)}):Play()
                callback(opt)
            end)
        end
        scroll.CanvasSize = UDim2.new(0, 0, 0, #newOptions * 28)
        
        if newOptions[1] then
            btn.Text = "  " .. label .. ": " .. tostring(newOptions[1])
            callback(newOptions[1])
        end
    end

    obj.UpdateOptions(options)
    return obj
end

