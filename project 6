local function extractUUID(obj)
    if not obj then return nil end
    for k, v in pairs(obj:GetAttributes()) do
        if type(v) == "string" and v:match("%w+%-%w+%-%w+%-%w+%-%w+") then return v end
    end
    for _, child in pairs(obj:GetChildren()) do
        if child:IsA("StringValue") and child.Value:match("%w+%-%w+%-%w+%-%w+%-%w+") then return child.Value end
    end
    if obj.Name:match("%w+%-%w+%-%w+%-%w+%-%w+") then return obj.Name end
    return nil
end

local function AutoScanBase()
    if LockedPlotObj then return end 
    local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    local plotsFolder = workspace:FindFirstChild("Plots")
    if not root or not plotsFolder then return end

    local closestPlot, shortestDist = nil, math.huge
    for _, plot in pairs(plotsFolder:GetChildren()) do
        local plotPos = (plot:IsA("Model") and plot.PrimaryPart) and plot.PrimaryPart.Position or plot:GetPivot().Position
        local dist = (root.Position - plotPos).Magnitude
        if dist < shortestDist then shortestDist = dist; closestPlot = plot end
    end
    
    if closestPlot and shortestDist < 150 then
        LockedPlotObj = closestPlot
        if BaseStatusBtn then
            BaseStatusBtn.Text = "📍 Locked: " .. closestPlot.Name
            BaseStatusBtn.TextColor3 = Theme.Success
        end
    end
end

