                        if frame.Name:match("%w+%-%w+%-%w+%-%w+%-%w+") then
                            local isTarget = false
                            
                            -- ค้นหาว่าโฟลเดอร์นี้มีชื่อตัวละครที่เราเลือกอยู่ข้างในไหม
                            for _, desc in pairs(frame:GetDescendants()) do
                                if (desc:IsA("TextLabel") or desc:IsA("TextButton")) and (desc.Text == SelectedBrainrot or desc.Text:match(SelectedBrainrot)) then
                                    isTarget = true
                                    break
                                end
                            end
                            
                            -- ถ้าเจอชื่อตรงกัน ดึง ID (ชื่อโฟลเดอร์) ไปขายทันที!
                            if isTarget then
                                ReplicatedStorage.Remotes.Sell:FireServer(frame.Name)
                            end
                        end
                    end
                end

                -- วิธีที่ 2 (แผนสำรอง): ค้นหาจากกระเป๋าแบบปกติเผื่อหน้า UI บัค
                local backpack = player:FindFirstChild("Backpack")
                if backpack then
                    for _, item in pairs(backpack:GetChildren()) do
                        if item.Name == SelectedBrainrot then
                            local uuid = nil
                            for k, v in pairs(item:GetAttributes()) do
                                if type(v) == "string" and v:match("%w+%-%w+%-%w+%-%w+%-%w+") then
                                    uuid = v
                                    break
                                end
                            end
                            if not uuid then
                                for _, child in pairs(item:GetChildren()) do
                                    if child:IsA("StringValue") and child.Value:match("%w+%-%w+%-%w+%-%w+%-%w+") then
                                        uuid = child.Value
                                        break
                                    end
                                end
                            end
                            if uuid then
                                ReplicatedStorage.Remotes.Sell:FireServer(uuid)
                            end
                        end
                    end
                end
            end)
        end

