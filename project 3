local function buildSelector()
    for _, c in ipairs(SV:GetChildren()) do
        if c:IsA("Frame") then c:Destroy() end
    end

    local seen = {}
    for _, t in ipairs(lp.Backpack:GetChildren()) do
        if t:IsA("Tool") and t:GetAttribute("GUID") then
            seen[t.Name] = true
        end
    end

    for name in pairs(seen) do
        local row = Instance.new("Frame", SV)
        row.Size = UDim2.new(1, 0, 0, 30) row.BackgroundTransparency = 1

        local cb = Instance.new("TextButton", row)
        cb.Size = UDim2.new(0, 20, 0, 20) cb.Position = UDim2.new(0, 2, 0.5, -10)
        cb.BackgroundColor3 = OG[name] and Color3.fromRGB(60, 200, 100) or Color3.fromRGB(40, 40, 60)
        cb.Text = OG[name] and "✔" or ""
        cb.TextColor3 = Color3.fromRGB(255, 255, 255) cb.Font = Enum.Font.GothamBold cb.TextSize = 12 cb.BorderSizePixel = 0
        Instance.new("UICorner", cb).CornerRadius = UDim.new(0, 5)

        local lbl = Instance.new("TextLabel", row)
        lbl.Size = UDim2.new(1, -30, 1, 0) lbl.Position = UDim2.new(0, 28, 0, 0)
        lbl.BackgroundTransparency = 1 lbl.Text = name
        lbl.TextColor3 = Color3.fromRGB(220, 220, 220) lbl.Font = Enum.Font.Gotham lbl.TextSize = 12
        lbl.TextXAlignment = Enum.TextXAlignment.Left lbl.TextTruncate = Enum.TextTruncate.AtEnd

        cb.MouseButton1Click:Connect(function()
            if OG[name] then
                OG[name] = nil
                cb.BackgroundColor3 = Color3.fromRGB(40, 40, 60) cb.Text = ""
            else
                OG[name] = 1
                cb.BackgroundColor3 = Color3.fromRGB(60, 200, 100) cb.Text = "✔"
            end
            local c = 0 for _ in pairs(OG) do c += 1 end
            ogLbl.Text = "Brainrot (skip): " .. c
        end)
    end
end

SelBtn.MouseButton1Click:Connect(function()
    SP.Visible = not SP.Visible
    if SP.Visible then buildSelector() end
end)

