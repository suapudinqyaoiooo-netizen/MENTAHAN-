Btn.MouseButton1Click:Connect(function()
    running = not running
    if not running then
        Btn.Text = "▶  START SELL" Btn.BackgroundColor3 = Color3.fromRGB(30, 20, 55)
        sLbl.Text = "Dihentikan — Sold: " .. sold sLbl.TextColor3 = Color3.fromRGB(160, 160, 160)
        local h = getHum() if h then h:UnequipTools() end
        return
    end
    Btn.Text = "⏹  STOP" Btn.BackgroundColor3 = Color3.fromRGB(20, 60, 25)
    sold = 0

    task.spawn(function()
        while running do
            local ogc, sellable = 0, {}
            for _, t in ipairs(lp.Backpack:GetChildren()) do
                if t:IsA("Tool") and t:GetAttribute("GUID") then
                    if OG[t.Name] then ogc += 1 else table.insert(sellable, t) end
                end
            end
            ogLbl.Text = "Brainrot (skip): " .. ogc

            if #sellable == 0 then
                sLbl.Text = "✅ Selesai!" sLbl.TextColor3 = Color3.fromRGB(80, 220, 120)
                qLbl.Text = "Antrian: 0  |  Sold: " .. sold
                running = false break
            end

            for _, tool in ipairs(sellable) do
                if not running or not tool or not tool.Parent then continue end
                local h = getHum() if h then h:EquipTool(tool) end
                task.wait()
                pcall(function() sellRemote:InvokeServer() end)
                sold += 1
                sLbl.Text = "🪙 " .. tool.Name sLbl.TextColor3 = Color3.fromRGB(255, 160, 60)
                qLbl.Text = "Sold: " .. sold
                local h2 = getHum() if h2 then h2:UnequipTools() end
            end
        end
        Btn.Text = "▶  START SELL" Btn.BackgroundColor3 = Color3.fromRGB(30, 20, 55)
        sLbl.Text = "Selesai — Sold: " .. sold sLbl.TextColor3 = Color3.fromRGB(80, 220, 120)
    end)
end)

