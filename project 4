task.spawn(function()
    while getgenv().RilzzHub_Loaded and task.wait(0.1) do
        if getgenv().RilzzHub_AutoTrain then
            pcall(function()
                local char = LocalPlayer.Character
                local hum = char and char:FindFirstChild("Humanoid")
                local backpack = LocalPlayer:FindFirstChild("Backpack")

                local currentTool = char and char:FindFirstChildOfClass("Tool")
                local isHoldingWeight = currentTool and currentTool:FindFirstChild("WeightBar", true)

                if not isHoldingWeight then
                    if hum then hum:UnequipTools() end
                    task.wait(0.1)
                    if backpack and hum then
                        for _, tool in pairs(backpack:GetChildren()) do
                            if tool:FindFirstChild("WeightBar", true) then
                                hum:EquipTool(tool)
                                break
                            end
                        end
                    end
                    local xLabel = PlayerGui:FindFirstChild("Backpack")
                        and PlayerGui.Backpack:FindFirstChild("Bar")
                        and PlayerGui.Backpack.Bar:FindFirstChild("Slot1")
                        and PlayerGui.Backpack.Bar.Slot1:FindFirstChild("X_Label")
                    if xLabel and getconnections then
                        for _, conn in pairs(getconnections(xLabel.MouseButton1Click)) do
                            conn:Fire()
                        end
                    end
                else
                    currentTool:Activate()
                end
            end)

            pcall(function()
                local kickUpgrades = PlayerGui:FindFirstChild("KickUpgrades")
                if kickUpgrades then
                    for _, bonus in pairs(kickUpgrades:GetChildren()) do
                        if bonus.Name == "Bonus" or bonus.Name == "PopBonus" then
                            if bonus.Visible then
                                if not bonus:GetAttribute("AutoClicked") then
                                    bonus:SetAttribute("AutoClicked", true)
                                    task.spawn(function()
                                        task.wait(0.2)
                                        local imgLabel = bonus:FindFirstChild("ImageLabel")
                                        local targets = {bonus}
                                        if imgLabel then table.insert(targets, imgLabel) end
                                        if getconnections then
                                            for _, target in pairs(targets) do
                                                pcall(function()
                                                    for _, conn in pairs(getconnections(target.InputBegan)) do
                                                        conn:Fire({UserInputType = Enum.UserInputType.MouseButton1, UserInputState = Enum.UserInputState.Begin})
                                                        conn:Fire({UserInputType = Enum.UserInputType.Touch, UserInputState = Enum.UserInputState.Begin})
                                                    end
                                                end)
                                                pcall(function()
                                                    for _, conn in pairs(getconnections(target.MouseButton1Click)) do conn:Fire() end
                                                end)
                                                pcall(function()
                                                    for _, conn in pairs(getconnections(target.Activated)) do conn:Fire() end
                                                end)
                                            end
                                        end
                                    end)
                                end
                            else
                                bonus:SetAttribute("AutoClicked", nil)
                            end
                        end
                    end
                end
            end)
        end
    end
end)

-- ================= SC KICK SCRIPT =================
local player = Players.LocalPlayer

local finalPosition = Vector3.new(703.29931640625, 11.34885025024414, 214.4062957763672)
local startPosition = Vector3.new(699.768, 3.167, 231.199)
local afterKickPosition = Vector3.new(-3175.41943359375, 49.99802017211914, 157.18048095703125)

local detecting = false
local toolConnection
local isRunning = false
local isEnabled = false
local currentSession = 0

local function getCharacter()
    local character = player.Character or player.CharacterAdded:Wait()
    local rootPart = character:WaitForChild("HumanoidRootPart")
    local humanoid = character:WaitForChild("Humanoid")
    return character, rootPart, humanoid
end

local function stopAll()
    detecting = false
    isRunning = false
    currentSession += 1
    if toolConnection then toolConnection:Disconnect() toolConnection = nil end
    local _, _, humanoid = getCharacter()
    if humanoid then
        humanoid.WalkSpeed = 16
        humanoid.JumpPower = 50
    end
end

local function safeTeleport(rootPart, pos, timeout, session)
    for attempt = 1, 3 do
        rootPart.CFrame = CFrame.new(pos)
        local waited = 0
        repeat
            task.wait(0.05)
            waited += 0.05
            if not isEnabled then return false end
            if currentSession ~= session then return false end
        until (rootPart.Position - pos).Magnitude < 5 or waited >= (timeout or 2)

        if (rootPart.Position - pos).Magnitude < 5 then
            return true
        end
        task.wait(0.3)
        if not isEnabled or currentSession ~= session then return false end
    end
    return false
end

local function onToolDetected(session)
    if not detecting then return end
    if not isEnabled then return end
    if currentSession ~= session then return end
    detecting = false
    isRunning = false
    if toolConnection then toolConnection:Disconnect() toolConnection = nil end
    task.spawn(function()
        task.wait(1)
        if isEnabled and currentSession == session then
            runSequence(false)
        end
    end)
end

function runSequence(isFirstRun)
    if isRunning then return end
    if not isEnabled then return end
    isRunning = true
    detecting = false
    currentSession += 1
    local session = currentSession

    if toolConnection then toolConnection:Disconnect() toolConnection = nil end

    local character, rootPart, humanoid = getCharacter()

    if isFirstRun then
        task.wait(2)
    else
        task.wait(0.5)
    end
    if not isEnabled or currentSession ~= session then isRunning = false return end

    if not rootPart or not rootPart.Parent then
        character, rootPart, humanoid = getCharacter()
    end

    local ok = safeTeleport(rootPart, startPosition, 2, session)
    if not ok or not isEnabled or currentSession ~= session then
        isRunning = false
        task.wait(2)
        if isEnabled then task.spawn(function() runSequence(false) end) end
        return
    end

    task.wait(0.6)
    if not isEnabled or currentSession ~= session then isRunning = false return end

    if (rootPart.Position - startPosition).Magnitude > 10 then
        isRunning = false
        task.wait(1)
        if isEnabled then task.spawn(function() runSequence(false) end) end
        return
    end

    local args = { [1] = 1 }
    game:GetService("ReplicatedStorage")
        :WaitForChild("Shared")
        :WaitForChild("Packages")
        :WaitForChild("Network")
        :WaitForChild("rev_KickEvent")
        :FireServer(unpack(args))

    ok = safeTeleport(rootPart, afterKickPosition, 2, session)
    if not ok or not isEnabled or currentSession ~= session then isRunning = false return end

    local waitStart = tick()
    while isEnabled and currentSession == session do
        local elapsed = tick() - waitStart
        if elapsed >= 17 then break end
        local c, rp = getCharacter()
        rp.CFrame = CFrame.new(afterKickPosition)
        task.wait(0.5)
    end
    if not isEnabled or currentSession ~= session then isRunning = false return end

    character, rootPart, humanoid = getCharacter()

    detecting = true
    isRunning = false

    toolConnection = character.ChildAdded:Connect(function(child)
        if child:IsA("Tool") then
            onToolDetected(session)
        end
    end)

    task.spawn(function()
        task.wait(0.15)
        if not detecting or currentSession ~= session then return end
        for _, child in ipairs(character:GetChildren()) do
            if child:IsA("Tool") then
                onToolDetected(session)
                return
            end
        end
    end)

    task.spawn(function()
        local stuckTimer = tick()

        while detecting and isEnabled and currentSession == session do
            local c, rp = getCharacter()
            rp.CFrame = CFrame.new(finalPosition)
            task.wait(0.5)

            if detecting and currentSession == session then
                for _, child in ipairs(c:GetChildren()) do
                    if child:IsA("Tool") then
                        onToolDetected(session)
                        return
                    end
                end

                if tick() - stuckTimer >= 60 then
                    detecting = false
                    isRunning = false
                    if toolConnection then toolConnection:Disconnect() toolConnection = nil end
                    task.wait(0.5)
                    if isEnabled then task.spawn(function() runSequence(false) end) end
                    return
                end
            end
        end
    end)
end

