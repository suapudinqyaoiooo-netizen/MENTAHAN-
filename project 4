        pcall(function() Window:Minimize() end)
    end)

    getgenv().RilzzHub_CloseOld = function()
        gui:Destroy()
        getgenv().RilzzHub_AutoCollect   = false
        getgenv().RilzzHub_AutoPerfectClaim = false
        getgenv().RilzzHub_AutoSell      = false
        getgenv().RilzzHub_AutoTrain     = false
        getgenv().RilzzHub_SkipList      = {}
        getgenv().RilzzHub_Loaded        = false
        autoKick         = false
        instantInteract  = false
