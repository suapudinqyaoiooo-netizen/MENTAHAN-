-- ================= AUTO KICK (FARTEZ VERSION) =================
local autoKick = false

Tabs.Main:AddToggle("AutoKick", {
    Title   = "Auto Kick (Warp Delay)",
    Default = false,
    Callback = function(v)
        autoKick = v
        getgenv().RilzzHub_AutoPerfectClaim = v

        if autoKick then
            task.spawn(function()
                local vaultArea = workspace:FindFirstChild("Areas") and workspace.Areas:FindFirstChild("Vault")

                while autoKick do
                    pcall(function()
                        local char, hrp, hum = getCharFull()
                        if not hrp or not hum then return end

                        hum:SetStateEnabled(Enum.HumanoidStateType.Dead, false)

                        -- TP ke KickReady lalu kick
                        ForcedTP(workspace.Areas.KickReady.CFrame + Vector3.new(0, 1.5, 0))
                        task.wait(0.2)

                        Net.rev_KickEvent:FireServer(kickValues[currentKickMode] or 1)
                        task.wait(0.2)
                        Net.rev_Transformed:FireServer()

                        -- Tunggu RandomBrainrotGui hilang
                        while PlayerGui:FindFirstChild("RandomBrainrotGui") and PlayerGui.RandomBrainrotGui.Enabled do
                            task.wait(0.1)
                        end

                        -- Cari monster di Debris
                        local targetMonster = nil
                        local foundTarget   = false

                        -- Hitung berapa mutation yang dipilih
                        local selectedCount = 0
                        for _, v in pairs(targetMutations) do if v then selectedCount = selectedCount + 1 end end

                        for i = 1, 50 do
                            if not autoKick then break end
                            for _, obj in pairs(workspace.Debris:GetChildren()) do
                                if obj:IsA("Model") and not obj:FindFirstChild("LuckyBlock") then
                                    local root = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
                                    if root then
                                        local inVault = true
                                        if vaultArea then
                                            if (root.Position - vaultArea:GetPivot().Position).Magnitude > 250 then
                                                inVault = false
                                            end
                                        end
                                        if inVault and (root.Position - hrp.Position).Magnitude < 500 then
                                            targetMonster = obj
                                            -- Cek mutation filter
                                            if selectedCount == 0 then
                                                -- Tidak ada filter = terima semua
                                                foundTarget = true
                                            else
                                                for _, mutName in ipairs(mutationList) do
                                                    if targetMutations[mutName] then
                                                        if obj:FindFirstChild(mutName) or obj:FindFirstChild(mutName, true) then
                                                            foundTarget = true
                                                            break
                                                        end
                                                    end
                                                end
                                                -- Normal = tidak punya mutation apapun
                                                if not foundTarget and targetMutations["Normal"] then
                                                    local hasMutation = false
                                                    for _, mutName in ipairs(mutationList) do
                                                        if mutName ~= "Normal" and (obj:FindFirstChild(mutName) or obj:FindFirstChild(mutName, true)) then
                                                            hasMutation = true
                                                            break
                                                        end
                                                    end
                                                    if not hasMutation then foundTarget = true end
                                                end
                                            end
                                            break
                                        end
                                    end
                                end
                            end
                            if targetMonster then break end
                            task.wait(0.1)
                        end

                        if targetMonster then
                            if foundTarget then
                                -- Tunggu warp delay lalu teleport ke safe zone
                                local timer = 0
                                while timer < warpDelayValue and autoKick do
                                    task.wait(1)
                                    timer = timer + 1
                                end

                                local safePos = Vector3.new(673.375, -6.903, 242.360)
                                local safeZone = workspace:FindFirstChild("Lobby") and workspace.Lobby:FindFirstChild("Safe")
                                if safeZone then
                                    safePos = safeZone:IsA("BasePart") and safeZone.Position or safeZone:GetPivot().Position
                                end

                                if autoKick then
                                    ForcedTP(CFrame.new(safePos + Vector3.new(0, 3, 0)))
                                    task.wait(2)
                                end
                            else
                                hum:SetStateEnabled(Enum.HumanoidStateType.Dead, true)
                                char:BreakJoints()
                                task.wait(3)
                            end
                        else
                            task.wait(0.5)
                        end
                    end)
                    task.wait(0.5)
                end
            end)
        else
            local char = LocalPlayer.Character
            if char and char:FindFirstChild("Humanoid") then
                char.Humanoid:SetStateEnabled(Enum.HumanoidStateType.Dead, true)
            end
        end
    end
})

