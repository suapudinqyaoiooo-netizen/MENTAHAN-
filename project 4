})

Tabs.Sell:AddToggle("AutoSell", {
    Title   = "Auto Sell Brainrot",
    Default = false,
    Callback = function(v)
        getgenv().RilzzHub_AutoSell = v
    end
})

task.spawn(function()
    while getgenv().RilzzHub_Loaded and task.wait(0.3) do
        if getgenv().RilzzHub_AutoSell then
            local tools = getSellableTools()

            if #tools == 0 then
                Fluent:Notify({
                    Title   = "Kick A Lucky Block",
                    Content = "Tidak ada Brainrot untuk dijual",
                    Duration = 3
                })
                getgenv().RilzzHub_AutoSell = false
                continue
            end

            local sold = 0
            for _, tool in ipairs(tools) do
                if not getgenv().RilzzHub_AutoSell then break end
                local hum = getHum()
                if hum then hum:EquipTool(tool) end
                task.wait(0.1)
                pcall(function() sellRemote:InvokeServer() end)
                sold += 1
                task.wait(0.1)
                local hum2 = getHum()
                if hum2 then hum2:UnequipTools() end
            end

            Fluent:Notify({
                Title   = "Kick A Lucky Block",
                Content = "Berhasil menjual " .. sold .. " Brainrot",
                Duration = 4
            })
            getgenv().RilzzHub_AutoSell = false
        end
    end
end)

