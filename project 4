-- ================= SELL TAB (RILZZ) =================
local function getHum()
    return LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
end

local function getBrainrots()
    local list = {}
    for _, t in ipairs(LocalPlayer.Backpack:GetChildren()) do
        if t:IsA("Tool") and t:GetAttribute("GUID") then
            if not table.find(list, t.Name) then
                table.insert(list, t.Name)
            end
        end
    end
    table.sort(list)
    return list
end

local function getSellableTools()
    local tools = {}
    for _, t in ipairs(LocalPlayer.Backpack:GetChildren()) do
        if t:IsA("Tool") and t:GetAttribute("GUID") then
            if not getgenv().RilzzHub_SkipList[t.Name] then
                table.insert(tools, t)
            end
        end
    end
    return tools
end

local SelectorDropdown = Tabs.Sell:AddDropdown("SkipSelector", {
    Title   = "Selector Brainrot (Skip Sell)",
    Values  = getBrainrots(),
    Multi   = true,
    Default = {},
    Callback = function(Value)
        getgenv().RilzzHub_SkipList = {}
        for name, state in pairs(Value) do
            if state then
                getgenv().RilzzHub_SkipList[name] = true
            end
        end
    end
})

Tabs.Sell:AddButton({
    Title = "Refresh Selector",
    Callback = function()
        local newValues = getBrainrots()
        pcall(function() SelectorDropdown:SetValues(newValues) end)
        Fluent:Notify({
